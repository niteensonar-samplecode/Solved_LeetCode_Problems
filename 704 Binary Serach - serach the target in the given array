using System;
					
public class Program
{
	public static void Main()
	{
		int[] nums= {1,2,3,4,9,15,16};
		int target =9;
		Console.WriteLine(findNum(nums,target));
	}
	static int findNum(int[] nums, int target)
	{
		int left =0;
		int right = nums.Length-1;
		while (left <= right)
		{
			int mid= left+(right-left)/2;
			if(nums[mid]== target)
				return mid;
			else if (nums[mid] < target)
				left= mid+1;
			else
				right= mid-1;
		}
		return -1;
	}
}
